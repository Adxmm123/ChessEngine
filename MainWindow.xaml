<Window
        x:Class="ChessEngine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chess Engine" Height="950" Width="1200"
        Background="#332402" ResizeMode="NoResize">

    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Top" 
                Background="#4A3410" 
                BorderBrush="#6B5322" 
                BorderThickness="0,0,0,2" 
                Padding="15">
            
            <StackPanel>
                <TextBlock Text="Chess Engine" 
                           FontSize="38" 
                           FontWeight="Bold" 
                           Foreground="#F0E6D2" 
                           HorizontalAlignment="Center"/>
                
                <TextBlock x:Name="StatusText" 
                           Text="White's turn" 
                           FontSize="18" 
                           FontWeight="SemiBold" 
                           Foreground="#D6D1C5" 
                           HorizontalAlignment="Center" 
                           Margin="0,5,0,10"/>
            </StackPanel>
        </Border>

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="760"/>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="#D6D1C5"
                    CornerRadius="8"
                    Padding="15">
                <Border.Effect>
                    <DropShadowEffect
                    Color="#000000"
                    BlurRadius="25"
                    ShadowDepth="8"
                    Opacity="0.45"/>
                </Border.Effect>

                <Grid x:Name="ChessBoard" Margin="1,1,1,1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="90"/>
                        <RowDefinition Height="90"/>
                        <RowDefinition Height="90"/>
                        <RowDefinition Height="90"/>
                        <RowDefinition Height="90"/>
                        <RowDefinition Height="90"/>
                        <RowDefinition Height="90"/>
                        <RowDefinition Height="90"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#49340A" BorderBrush="#8C6B29" BorderThickness="2" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Engine Information" FontSize="35" FontWeight="Bold" Foreground="#F0E6D2" Margin="0,0,0,20"/>
                    <Separator/>
                    <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="#D6D1C5" Margin="0,15,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="175"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Depth:" Foreground="#AC9D7A" FontSize="18"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DepthText" Text="6" Foreground="#D6D1C5" FontSize="18"/>
                        <TextBlock Grid.Row="1" Text="Thinking Time:" Foreground="#AC9D7A" FontSize="18"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ThinkingTimeText" Text="5s" Foreground="#D6D1C5" FontSize="18"/>
                        <TextBlock Grid.Row="2" Text="Endgame Depth:" Foreground="#AC9D7A" FontSize="18"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="EndgameDepthText" Text="8" Foreground="#D6D1C5" FontSize="18"/>
                        <TextBlock Grid.Row="3" Text="Player Colour:" Foreground="#AC9D7A" FontSize="18"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="PlayerColourText" Text="White" Foreground="#D6D1C5" FontSize="18"/>
                    </Grid>
                    <Separator Margin="0,20,0,20"/>
                    <TextBlock Text="Search" FontWeight="Bold" FontSize="28" Foreground="#D6D1C5"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="175"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Current Evaluation:" Foreground="#AC9D7A" FontSize="18"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="EvaluationText" Text="+0" Foreground="#D6D1C5" FontSize="18"/>
                        <TextBlock Grid.Row="1" Text="Engine Evaluation:" Foreground="#AC9D7A" FontSize="18"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="BestEvaluationText" Text="+0" Foreground="#D6D1C5" FontSize="18"/>
                        <TextBlock Grid.Row="2" Text="Best Move:" Foreground="#AC9D7A" FontSize="18"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="BestMoveText" Text="-" Foreground="#D6D1C5" FontSize="18"/>
                        </Grid>
                    <Separator Margin="0,20,0,20"/>
                    <Button Content="Home" Height="40" FontWeight="Bold" FontSize="20" Click="Home_Click" Background="#817047" Foreground="#D6D1C5"/>
                </StackPanel>
            </Border>






            <Border x:Name="GameOverOverlay"
                    Visibility="Collapsed"
                    Background="#CC000000"
                    CornerRadius="12">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <TextBlock x:Name="GameOverTitle"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="GameOverSubtitle"
                               FontSize="20"
                               Foreground="#cccccc"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,32"/>

                    <Button x:Name="PlayAgainButton"
                            Content="Play Again"
                            FontSize="16"
                            FontWeight="Bold"
                            Padding="24,12"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="PlayAgain_Clicked"/>
                </StackPanel>
            </Border>

            <Border x:Name="PromotionOverlay"
                    Visibility="Collapsed"
                    Background="#CC000000"
                    CornerRadius="12">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <TextBlock Text="Choose a piece for promotion:"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>

                    <WrapPanel HorizontalAlignment="Center"
                               Orientation="Horizontal"
                               Margin="0,0,0,0">

                        <Button x:Name="PromotionQueenButton"
                                Content="♕ Queen"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="16,12"
                                Margin="8"
                                Width="100"
                                Height="50"
                                Background="#4CAF50"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="PromotionQueenButton_Click"/>


                        <Button x:Name="PromotionRookButton"
                                Content="♖ Rook"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="16,12"
                                Margin="8"
                                Width="100"
                                Height="50"
                                Background="#2196F3"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="PromotionRookButton_Click"/>


                        <Button x:Name="PromotionBishopButton"
                                Content="♗ Bishop"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="16,12"
                                Margin="8"
                                Width="100"
                                Height="50"
                                Background="#FF9800"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="PromotionBishopButton_Click"/>


                        <Button x:Name="PromotionKnightButton"
                                Content="♘ Knight"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="16,12"
                                Margin="8"
                                Width="100"
                                Height="50"
                                Background="#9C27B0"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="PromotionKnightButton_Click"/>

                    </WrapPanel>

                </StackPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>