<Window x:Class="ChessEngine.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chess Engine" Height="600" Width="420"
        Background="#332402" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <StackPanel VerticalAlignment="Center" Margin="30,0">


        <TextBlock Text="Chess Engine"
                   FontSize="36" FontWeight="Bold"
                   Foreground="#D6D1C5"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>

        <TextBlock Text="vs Computer"
                   FontSize="14" Foreground="#817047"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,48"/>


        <Button x:Name="PlayButton"
                Content="Play"
                FontSize="16" FontWeight="Bold"
                Height="50" Margin="0,0,0,16"
                Background="#817047" Foreground="#D6D1C5"
                BorderThickness="0" Cursor="Hand"
                Click="PlayButton_Click"/>


        <TextBlock FontSize="13" Foreground="#AC9D7A"
                   Margin="0,0,0,6">
            <Run Text="Depth: "/>
            <Run x:Name="DifficultyLabel" Text="1" FontWeight="Bold" Foreground="#D6D1C5"/>
        </TextBlock>

        <Slider x:Name="DifficultySlider"
                Minimum="1" Maximum="8" Value="4"
                IsSnapToTickEnabled="True" TickFrequency="1"
                SmallChange="1" LargeChange="1"
                Margin="0,0,0,32"
                ValueChanged="DifficultySlider_ValueChanged"/>

        <TextBlock FontSize="13" Foreground="#AC9D7A"
                   Margin="0,0,0,6">
            <Run Text="Thinking Time: "/>
            <Run x:Name="TimeLabel" Text="10s" FontWeight="Bold" Foreground="#D6D1C5"/>
        </TextBlock>

        <Slider x:Name="TimeSlider"
                Minimum="1" Maximum="8" Value="4"
                IsSnapToTickEnabled="True" TickFrequency="1"
                SmallChange="1" LargeChange="1"
                Margin="0,0,0,32"
                ValueChanged="TimeSlider_ValueChanged"/>

        
        <CheckBox x:Name="EndGameDepthCheckBox"
                  
                  Content="Enable Endgame Depth (+2)"
                  Foreground="#AC9D7A" FontSize="13"
                  Margin="0,0,0,32"
                  Checked="EndGameDepthCheckBox_Checked"
                  Unchecked="EndGameDepthCheckBox_Unchecked" IsChecked="False"/>


        <TextBlock Text="Play as" FontSize="13"
                   Foreground="#AC9D7A" Margin="0,0,0,8"/>

        <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,40">
            <RadioButton x:Name="PlayWhite"
                         Content="White" IsChecked="True"
                         Foreground="#D6D1C5" FontSize="14"
                         Margin="0,0,24,0"/>
            <RadioButton x:Name="PlayBlack"
                         Content="Black"
                         Foreground="#D6D1C5" FontSize="14"/>
        </WrapPanel>


        <Button Content="Quit"
                FontSize="13" Height="38"
                Background="#574721" Foreground="#D6D1C5"
                BorderThickness="0" Cursor="Hand"
                Click="QuitButton_Click"/>

    </StackPanel>

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>


        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>


                            <Border Grid.Row="1"
                                Height="4" CornerRadius="2"
                                Background="#574721"
                                VerticalAlignment="Center"/>

                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>

                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="#817047"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>

                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="14" Height="14"
                                                     Fill="#D6D1C5"
                                                     Stroke="#AC9D7A" StrokeThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#817047"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <Grid Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse Stroke="#817047" StrokeThickness="2" Fill="#574721"/>

                                <Ellipse Width="8" Height="8"
                                 Fill="#D6D1C5"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent},Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#574721"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <Grid Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0">
                                <Border CornerRadius="3"
                                BorderBrush="#817047" BorderThickness="2"
                                Background="#574721"/>

                                <TextBlock Text="✓"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="#D6D1C5"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent},Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </Window.Resources>


</Window>
    
    